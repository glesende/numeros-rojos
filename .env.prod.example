# Puerto Nginx (production)
NGINX_PORT=80

# Puerto Frontend (production) - no expuesto en prod, sirve desde nginx
FRONTEND_PORT=3000

# Puerto MySQL
MYSQL_PORT=3306

# Puerto Redis
REDIS_PORT=6379

# Database
DB_DATABASE=numeros_rojos
DB_USERNAME=app
DB_PASSWORD=changeme-in-production
DB_ROOT_PASSWORD=changeme-in-production

# JWT
JWT_SECRET=changeme-in-production-generate-with-artisan

# BeSoccer API
BESOCCER_API_KEY=
BESOCCER_BASE_URL=https://apiv3.besoccer.com

# Cache TTL (seconds)
CACHE_TTL_STANDINGS=3600
CACHE_TTL_PLAYER_STATS=1800
CACHE_TTL_LEAGUE_STATS=3600

# Frontend - URL de producción
VITE_API_URL=https://numerosrojos.net/api/v1
