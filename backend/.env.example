APP_NAME="Numeros Rojos API"
APP_ENV=local
APP_KEY=base64:changethiskey
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=America/Argentina/Buenos_Aires
FRONTEND_URL=https://numerosrojos.com.ar

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=numeros_rojos
DB_USERNAME=app
DB_PASSWORD=secret

CACHE_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

JWT_SECRET=changeme-in-production
JWT_TTL=60

BESOCCER_API_KEY=
BESOCCER_BASE_URL=https://apiv3.besoccer.com

CACHE_TTL_STANDINGS=3600
CACHE_TTL_PLAYER_STATS=1800
CACHE_TTL_LEAGUE_STATS=3600
