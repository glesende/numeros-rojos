{
    "name": "numeros-rojos/api",
    "description": "Portal de Transparencia Deportiva - Independiente API",
    "type": "project",
    "require": {
        "php": "^8.2",
        "laravel/lumen-framework": "^10.0",
        "illuminate/redis": "^10.0",
        "predis/predis": "^2.0",
        "tymon/jwt-auth": "^2.0",
        "guzzlehttp/guzzle": "^7.0",
        "league/csv": "^9.0",
        "league/flysystem-local": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Seeders\\": "database/seeders/",
            "Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
